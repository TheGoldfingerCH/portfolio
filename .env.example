# --- Frontend (Astro) ---
# Public URL of the chatbot API. Leave empty to hide the chatbot.
# Local dev: point this at the deployed Vercel function (or run `vercel dev`).
# Prod: this is injected by the GitHub Action build (and the Vercel deploy).
# Example: https://allrun-chat.vercel.app/api/chat
PUBLIC_CHAT_API_URL=

# Canonical site URL used for sitemap / OG tags.
SITE_URL=http://localhost:4321

# --- Backend (Vercel function) — used only by api/chat.ts on Vercel ---
# Free Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Comma-separated list of allowed origins for CORS (empty = allow any).
# Set this on Vercel to: https://allrun.ch,https://www.allrun.ch
ALLOWED_ORIGINS=
