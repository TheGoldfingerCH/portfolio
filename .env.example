# Google Gemini API key for the chatbot (required when CHATBOT_ENABLED=true).
# Free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Toggle the chatbot UI + endpoint (set to "true" to enable)
CHATBOT_ENABLED=false

# Public site URL used for canonical links / sitemap
SITE_URL=http://localhost:4321

# Server port (Node adapter)
HOST=0.0.0.0
PORT=4321
