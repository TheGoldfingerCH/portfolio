---
import { profile } from '../data/profile';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="bg-hero-grid relative overflow-hidden">
  <div class="container-page section pt-28 md:pt-36 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-7 fade-up">
      <div class="inline-flex items-center gap-2 chip mb-6">
        <span class="inline-block w-2 h-2 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.8)]"></span>
        {t.hero.status}
      </div>

      <p class="eyebrow mb-3">{t.hero.kicker}</p>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-gradient">
        {t.hero.title}
      </h1>
      <p class="mt-6 text-lg text-[color:var(--color-text-soft)] max-w-2xl">
        {t.hero.lead}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#contact" class="btn btn-primary">{t.hero.ctaContact}</a>
        <a href="#projects" class="btn btn-ghost">{t.hero.ctaProjects}</a>
      </div>

      <div class="mt-10 flex items-center gap-5 text-sm text-[color:var(--color-text-muted)]">
        <a href={profile.links.linkedin} target="_blank" rel="noreferrer noopener" class="hover:text-white transition">LinkedIn</a>
        <span aria-hidden="true">·</span>
        <a href={profile.links.github} target="_blank" rel="noreferrer noopener" class="hover:text-white transition">GitHub</a>
        <span aria-hidden="true">·</span>
        <a href={`mailto:${profile.email}`} class="hover:text-white transition">{profile.email}</a>
      </div>
    </div>

    <div class="md:col-span-5 flex justify-center md:justify-end fade-up">
      <div class="relative">
        <div class="absolute -inset-4 rounded-full bg-gradient-to-br from-indigo-500/30 to-purple-500/20 blur-2xl"></div>
        <div class="relative w-56 h-56 md:w-72 md:h-72 rounded-full overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
          <img
            src={profile.avatar}
            alt={`Portrait — ${profile.name}`}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
            onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=&quot;w-full h-full flex items-center justify-center text-6xl font-display text-indigo-300&quot;>NG</div>';"
          />
        </div>
      </div>
    </div>
  </div>
</section>
