---
import { defaultLocale, locales, localeLabels, type Locale } from '../i18n/ui';
import { useTranslations, pathWithoutLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const currentPath = pathWithoutLocale(Astro.url.pathname);

function localePath(loc: Locale) {
  if (loc === defaultLocale) return currentPath === '/' ? '/' : currentPath;
  return `/${loc}${currentPath === '/' ? '' : currentPath}`;
}
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--color-bg)]/75 border-b border-[color:var(--color-border)]">
  <div class="container-page flex items-center justify-between h-16">
    <a href={localePath(locale)} class="font-semibold tracking-tight text-lg flex items-center gap-2 group">
      <span class="inline-block w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500 via-fuchsia-500 to-purple-500 flex items-center justify-center text-sm font-bold text-white">NG</span>
      <span class="hidden sm:inline text-[color:var(--color-text)] transition">Nicolas Geng</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm text-[color:var(--color-text-soft)]">
      <a href="#about" class="hover:text-[color:var(--color-text)] transition">{t.nav.about}</a>
      <a href="#skills" class="hover:text-[color:var(--color-text)] transition">{t.nav.skills}</a>
      <a href="#projects" class="hover:text-[color:var(--color-text)] transition">{t.nav.projects}</a>
      <a href="#experience" class="hover:text-[color:var(--color-text)] transition">{t.nav.experience}</a>
      <a href="#contact" class="hover:text-[color:var(--color-text)] transition">{t.nav.contact}</a>
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden sm:flex items-center gap-1 text-xs">
        {locales.map((loc) => (
          <a
            href={localePath(loc)}
            aria-current={loc === locale ? 'true' : undefined}
            class:list={[
              'px-2 py-1 rounded-md uppercase tracking-wider transition',
              loc === locale
                ? 'bg-[color:var(--color-surface)] text-[color:var(--color-text)] border border-[color:var(--color-border)]'
                : 'text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)]',
            ]}
            aria-label={localeLabels[loc]}
          >
            {loc}
          </a>
        ))}
      </div>

      <button id="theme-toggle" type="button" class="theme-toggle ml-1" aria-label="Toggle theme">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>
    </div>
  </div>

  <div class="md:hidden border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-soft)]/85 backdrop-blur">
    <nav class="container-page flex items-center justify-between py-2 text-sm overflow-x-auto whitespace-nowrap gap-5 text-[color:var(--color-text-muted)]">
      <a href="#about" class="hover:text-[color:var(--color-text)] transition">{t.nav.about}</a>
      <a href="#skills" class="hover:text-[color:var(--color-text)] transition">{t.nav.skills}</a>
      <a href="#projects" class="hover:text-[color:var(--color-text)] transition">{t.nav.projects}</a>
      <a href="#experience" class="hover:text-[color:var(--color-text)] transition">{t.nav.experience}</a>
      <a href="#contact" class="hover:text-[color:var(--color-text)] transition">{t.nav.contact}</a>
      <div class="flex items-center gap-1 text-xs ml-auto pl-3 border-l border-[color:var(--color-border)]">
        {locales.map((loc) => (
          <a href={localePath(loc)} class:list={['px-1.5', loc === locale ? 'text-[color:var(--color-text)]' : 'text-[color:var(--color-text-muted)]']}>
            {loc.toUpperCase()}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>
