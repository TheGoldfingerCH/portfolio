---
import { projects } from '../data/projects';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="projects" class="section">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-4">
        <p class="eyebrow">03</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold mt-2 tracking-tight">{t.sections.projects.title}</h2>
      </div>
      <div class="md:col-span-8">
        <p class="text-lg text-[color:var(--color-text-soft)]">{t.sections.projects.lead}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map((project) => (
        <article class="card p-6 flex flex-col reveal">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-display text-xl font-semibold tracking-tight">{project.title}</h3>
            <span class:list={[
              'chip',
              project.status === 'live' ? '' : 'chip-muted',
            ]}>
              <span class:list={[
                'inline-block w-1.5 h-1.5 rounded-full',
                project.status === 'live' ? 'bg-emerald-400' : 'bg-zinc-400',
              ]}></span>
              {t.sections.projects.status[project.status]}
            </span>
          </div>

          <p class="text-[color:var(--color-text-soft)] mb-5 grow">{project.summary[locale]}</p>

          <div class="flex flex-wrap gap-1.5 mb-5">
            {project.tags.map((tag) => <span class="chip chip-muted">{tag}</span>)}
          </div>

          <div class="flex gap-2">
            {project.url && (
              <a href={project.url} target="_blank" rel="noreferrer noopener" class="btn btn-primary text-sm">
                {t.sections.projects.view} ↗
              </a>
            )}
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noreferrer noopener" class="btn btn-ghost text-sm">
                {t.sections.projects.code}
              </a>
            )}
          </div>
        </article>
      ))}

    </div>
  </div>
</section>
