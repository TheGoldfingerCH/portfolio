---
import { experiences } from '../data/experiences';
import CompanyAvatar from './CompanyAvatar.astro';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const palette = ['#6366f1', '#a855f7', '#06b6d4', '#10b981', '#f59e0b', '#ec4899', '#3b82f6'];
function tintFor(seed: string) {
  let hash = 0;
  for (let i = 0; i < seed.length; i++) hash = (hash * 31 + seed.charCodeAt(i)) >>> 0;
  return palette[hash % palette.length];
}
---

<section id="experience" class="section bg-[color:var(--color-bg-soft)] border-y border-[color:var(--color-border)]">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-4">
        <p class="eyebrow">05</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold mt-2 tracking-tight">{t.sections.experience.title}</h2>
      </div>
      <div class="md:col-span-8">
        <p class="text-lg text-[color:var(--color-text-soft)]">{t.sections.experience.lead}</p>
      </div>
    </div>

    <ol class="space-y-5">
      {experiences.map((job) => {
        const tint = tintFor(job.id);
        return (
          <li class="card p-6 md:p-7 reveal">
            <div class="flex items-start gap-4">
              <CompanyAvatar name={job.company} id={job.id} domain={job.domain} />
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <h3 class="font-display text-lg font-semibold tracking-tight text-[color:var(--color-text)]">{job.company}</h3>
                  <span class="text-[color:var(--color-text-muted)] text-sm">·</span>
                  <span class="text-sm text-[color:var(--color-text-muted)]">{job.location}</span>
                </div>
                <div class="mt-1 flex flex-wrap items-baseline gap-x-3">
                  <span class="font-medium" style={`color:${tint}`}>{job.role[locale]}</span>
                  <span class="text-[color:var(--color-text-muted)] text-sm">{job.period}</span>
                </div>
                <ul class="mt-3 space-y-1.5">
                  {job.bullets[locale].map((bullet) => (
                    <li class="flex gap-2 text-sm leading-relaxed text-[color:var(--color-text-soft)]">
                      <span class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full shrink-0" style={`background:${tint}`}></span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</section>
