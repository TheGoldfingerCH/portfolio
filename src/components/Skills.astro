---
import { skills, softSkillColors } from '../data/skills';
import { languages } from '../data/languages';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import TechIcon from './TechIcon.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="skills" class="section bg-[color:var(--color-bg-soft)] border-y border-[color:var(--color-border)] bg-dotted">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-4">
        <p class="eyebrow">02</p>
        <h2 class="font-display text-3xl md:text-4xl font-semibold mt-2 tracking-tight">{t.sections.skills.title}</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Left: Languages + Soft skills -->
      <aside class="lg:col-span-4 space-y-6 reveal">
        <div class="card p-6">
          <h3 class="eyebrow mb-4 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-cyan-400"></span>
            {t.sections.skills.languagesTitle}
          </h3>
          <ul class="space-y-3">
            {languages.map((lang) => (
              <li class="flex items-center justify-between gap-3">
                <span class="flex items-center gap-3">
                  <span class="text-xl" aria-hidden="true">{lang.flag}</span>
                  <span class="text-[color:var(--color-text)] font-medium">{lang.name[locale]}</span>
                </span>
                <span class:list={[
                  'text-xs px-2 py-1 rounded-full',
                  lang.badge === 'native'
                    ? 'bg-[color:var(--color-accent-3)]/15 text-cyan-300 border border-cyan-400/30'
                    : lang.badge === 'fluent'
                      ? 'bg-[color:var(--color-accent-2)]/15 text-purple-300 border border-purple-400/30'
                      : 'bg-[color:var(--color-accent-4)]/15 text-amber-300 border border-amber-400/30',
                ]}>
                  {lang.level[locale]}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-6">
          <h3 class="eyebrow mb-4 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-pink-400"></span>
            {t.sections.skills.soft.title}
          </h3>
          <div class="flex flex-wrap gap-2">
            {t.sections.skills.soft.items.map((item, i) => (
              <span class="soft-chip" style={`--tint: ${softSkillColors[i % softSkillColors.length]}`}>
                {item}
              </span>
            ))}
          </div>
        </div>
      </aside>

      <!-- Right: Tech stack -->
      <div class="lg:col-span-8 reveal">
        <h3 class="eyebrow mb-4">{t.sections.skills.techStack}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {skills.map((group) => (
            <div class="cat-card" style={`--tint: ${group.tint}`}>
              <div class="cat-label mb-3">{t.sections.skills.groups[group.key]}</div>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="tech-chip" style={item.color ? `--tint: ${item.color}` : undefined}>
                    {item.icon ? (
                      <TechIcon slug={item.icon} color={item.color} />
                    ) : (
                      <span class="inline-block w-2 h-2 rounded-full" style={`background:${item.color ?? 'currentColor'}`}></span>
                    )}
                    <span>{item.name}</span>
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
