---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatLauncher from '../components/ChatLauncher.astro';
import { defaultLocale, locales, type Locale } from '../i18n/ui';
import { useTranslations, pathWithoutLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const currentPath = pathWithoutLocale(Astro.url.pathname);

function localePath(loc: Locale) {
  if (loc === defaultLocale) return currentPath === '/' ? '/' : currentPath;
  return `/${loc}${currentPath === '/' ? '' : currentPath}`;
}

const chatbotEnabled = (process.env.CHATBOT_ENABLED ?? 'false') === 'true';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nicolas Geng',
  jobTitle: 'Data Science & AI Specialist',
  url: siteUrl || undefined,
  email: 'mailto:contact@allrun.ch',
  sameAs: [
    'https://www.linkedin.com/in/nicolas-geng/',
    'https://github.com/TheGoldfingerCH',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'La Tour-de-Peilz',
    addressCountry: 'CH',
  },
  knowsAbout: ['Data Science', 'Machine Learning', 'Artificial Intelligence', 'Marketing Analytics', 'Python'],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a0a0a" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fafafa" />
    <script is:inline>
      // Apply persisted theme BEFORE first paint to avoid FOUC.
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = stored || (prefersLight ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Nicolas Geng" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {locales.map((loc) => (
      <link rel="alternate" hreflang={loc} href={`${siteUrl}${localePath(loc)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localePath(defaultLocale)}`} />
    <link rel="canonical" href={`${siteUrl}${localePath(locale)}`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={`${siteUrl}${localePath(locale)}`} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_CH' : locale === 'de' ? 'de_CH' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-white focus:text-black focus:px-3 focus:py-1 focus:rounded">Skip to content</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    {chatbotEnabled && <ChatLauncher locale={locale} />}

    <script is:inline>
      // Reveal-on-scroll: any element with .reveal becomes .is-visible when entering the viewport.
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
